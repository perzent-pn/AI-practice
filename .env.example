# ============================================================================
# Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values

# --- Database ---
DATABASE_URL="file:./dev.db"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret
AUTH_SECRET="your-auth-secret-here"

